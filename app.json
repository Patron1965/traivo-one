{
  "expo": {
    "name": "Nordfield",
    "slug": "fltapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "fltapp",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF7ED"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fltapp.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Nordfield behöver kameran för att ta bilder av objekt och avvikelser",
        "NSLocationWhenInUseUsageDescription": "Nordfield behöver din position för GPS-tracking och navigering",
        "NSPhotoLibraryUsageDescription": "Nordfield behöver åtkomst till dina foton för att bifoga bilder"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF7ED"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.fltapp.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}